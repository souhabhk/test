import os
from docx import Document

def generate_template():
    os.makedirs("src/templates", exist_ok=True)
    doc = Document()
    
    headings = [
        "Vue d'ensemble",
        "Composants",
        "Flux de données",
        "Déploiement",
        "Sécurité",
        "Décisions techniques (ADR)"
    ]
    
    for heading in headings:
        doc.add_heading(heading, level=1)
        doc.add_paragraph("Contenu de la section...")
        
    doc.add_heading("Règles de validation", level=2)
    table = doc.add_table(rows=1, cols=3)
    table.style = "Table Grid"
    
    hdr_cells = table.rows[0].cells
    hdr_cells[0].text = "Section"
    hdr_cells[1].text = "Obligatoire"
    hdr_cells[2].text = "Mots minimum"
    
    rules = [
        ("Vue d'ensemble", "Oui", "80"),
        ("Composants", "Oui", "150"),
        ("Flux de données", "Oui", "100"),
        ("Déploiement", "Oui", "50"),
        ("Sécurité", "Oui", "40"),
        ("Décisions techniques", "Non", "50"),
        ("Total document", "Oui", "600")
    ]
    
    for section, mandatory, min_words in rules:
        row_cells = table.add_row().cells
        row_cells[0].text = section
        row_cells[1].text = mandatory
        row_cells[2].text = min_words
        
    output_path = "src/templates/template_archi.docx"
    doc.save(output_path)
    print(f"Template generated: {output_path}")

if __name__ == "__main__":
    generate_template()