import os
from docx import Document

def generate_spec_template(output_path: str) -> None:
    """Generates the SPEC reference template .docx with headings and validation rules table."""
    doc = Document()
    
    spec_headings = [
        "Introduction",
        "Contexte",
        "Acteurs",
        "Exigences fonctionnelles",
        "Contraintes",
        "Glossaire"
    ]
    
    for heading_text in spec_headings:
        doc.add_heading(heading_text, level=1)
        doc.add_paragraph(f"[Insérer le contenu pour la section {heading_text} ici.]")
        
    doc.add_heading("Règles de validation", level=1)
    table = doc.add_table(rows=1, cols=3)
    table.style = 'Table Grid'
    
    header_cells = table.rows[0].cells
    header_cells[0].text = "Section"
    header_cells[1].text = "Obligatoire"
    header_cells[2].text = "Mots minimum"
    
    rules_data = [
        ("Introduction", "Oui", "50"),
        ("Contexte", "Oui", "100"),
        ("Acteurs", "Oui", "30"),
        ("Exigences fonctionnelles", "Oui", "200"),
        ("Contraintes", "Oui", "50"),
        ("Glossaire", "Non", "20"),
        ("Total document", "Oui", "500")
    ]
    
    for section, mandatory, min_words in rules_data:
        row_cells = table.add_row().cells
        row_cells[0].text = section
        row_cells[1].text = mandatory
        row_cells[2].text = min_words
        
    os.makedirs(os.path.dirname(output_path), exist_ok=True)
    doc.save(output_path)

if __name__ == "__main__":
    generate_spec_template("src/templates/template_spec.docx")