import os
from docx import Document

def create_spec_template():
    doc = Document()
    
    headings = [
        "Introduction",
        "Contexte",
        "Acteurs",
        "Exigences fonctionnelles",
        "Contraintes",
        "Glossaire"
    ]
    
    for heading in headings:
        doc.add_heading(heading, level=1)
        if heading == "Exigences fonctionnelles":
            doc.add_paragraph("EF-1: Description de l'exigence fonctionnelle...")
        else:
            doc.add_paragraph(f"[Contenu pour {heading}]")
            
    doc.add_heading("Règles de validation", level=1)
    table = doc.add_table(rows=1, cols=3)
    table.style = "Table Grid"
    
    for i, header in enumerate(["Section", "Obligatoire", "Mots minimum"]):
        table.rows[0].cells[i].text = header
        
    rules = [
        ("Introduction", "Oui", "50"),
        ("Contexte", "Oui", "100"),
        ("Acteurs", "Oui", "30"),
        ("Exigences fonctionnelles", "Oui", "200"),
        ("Contraintes", "Oui", "50"),
        ("Glossaire", "Non", "20"),
        ("Total document", "Oui", "500")
    ]
    
    for section, oblig, mots in rules:
        row = table.add_row()
        row.cells[0].text = section
        row.cells[1].text = oblig
        row.cells[2].text = mots
        
    output_path = os.path.join("src", "templates", "template_spec.docx")
    os.makedirs(os.path.dirname(output_path), exist_ok=True)
    doc.save(output_path)

if __name__ == "__main__":
    create_spec_template()