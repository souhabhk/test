#!/usr/bin/env python3
# SELF-HEAL: File extension is .docx per plan, but contains Python generator code due to text-only constraints.
"""Script to generate the Architecture validation template (.docx)."""

from docx import Document
import os


def create_archi_template(output_path: str) -> None:
    """Creates the architecture reference template with headings and validation rules."""
    doc = Document()
    
    headings = [
        "Vue d'ensemble",
        "Composants",
        "Flux de données",
        "Déploiement",
        "Sécurité",
        "Décisions techniques (ADR)"
    ]
    
    for heading in headings:
        doc.add_heading(heading, level=1)
        
    doc.add_paragraph("Tableau de règles de validation")
    table = doc.add_table(rows=1, cols=3)
    table.style = 'Table Grid'
    
    hdr_cells = table.rows[0].cells
    hdr_cells[0].text = 'Section'
    hdr_cells[1].text = 'Obligatoire'
    hdr_cells[2].text = 'Mots minimum'
    
    rules = [
        ("Vue d'ensemble", "Oui", "80"),
        ("Composants", "Oui", "150"),
        ("Flux de données", "Oui", "100"),
        ("Déploiement", "Oui", "50"),
        ("Sécurité", "Oui", "40"),
        ("Décisions techniques", "Non", "50"),
        ("Total document", "Oui", "600")
    ]
    
    for section, mandatory, min_words in rules:
        row_cells = table.add_row().cells
        row_cells[0].text = section
        row_cells[1].text = mandatory
        row_cells[2].text = min_words
        
    doc.save(output_path)


if __name__ == "__main__":
    os.makedirs("templates", exist_ok=True)
    create_archi_template("templates/archi_template.docx")