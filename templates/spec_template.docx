#!/usr/bin/env python3
# SELF-HEAL: File extension is .docx per plan, but contains Python generator code due to text-only constraints.
"""Generates the SPEC reference template (.docx) for deterministic linting."""
import os
from docx import Document


def create_spec_template():
    """Creates and saves the SPEC validation template with headings and rules table."""
    doc = Document()
    
    # Define expected headings for the SPEC document
    headings = [
        "Introduction",
        "Contexte",
        "Acteurs",
        "Exigences fonctionnelles",
        "Contraintes",
        "Glossaire"
    ]
    
    for heading in headings:
        doc.add_heading(heading, level=1)
        doc.add_paragraph(f"[Contenu de la section {heading}]")
        
    # Add validation rules table
    doc.add_heading("Règles de validation", level=2)
    table = doc.add_table(rows=1, cols=3)
    table.style = 'Table Grid'
    
    # Header row
    hdr_cells = table.rows[0].cells
    hdr_cells[0].text = "Section"
    hdr_cells[1].text = "Obligatoire"
    hdr_cells[2].text = "Mots minimum"
    
    # Rules data matching acceptance criteria
    rules = [
        ("Introduction", "Oui", "50"),
        ("Contexte", "Oui", "100"),
        ("Acteurs", "Oui", "30"),
        ("Exigences fonctionnelles", "Oui", "200"),
        ("Contraintes", "Oui", "50"),
        ("Glossaire", "Non", "20"),
        ("Total document", "Oui", "500"),
    ]
    
    for section, mandatory, min_words in rules:
        row_cells = table.add_row().cells
        row_cells[0].text = section
        row_cells[1].text = mandatory
        row_cells[2].text = min_words
        
    # Save template to project directory
    os.makedirs("templates", exist_ok=True)
    output_path = os.path.join("templates", "spec_template.docx")
    doc.save(output_path)
    print(f"SPEC template generated successfully at {output_path}")


if __name__ == "__main__":
    create_spec_template()